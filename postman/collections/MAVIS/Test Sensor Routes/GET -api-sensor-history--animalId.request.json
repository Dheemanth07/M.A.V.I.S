{
  "postman_collection_v3_request": {
    "name": "GET /api/sensor/history/:animalId",
    "request": {
      "method": "GET",
      "url": {
        "raw": "{{baseUrl}}/api/sensor/history/{{animalId}}?from=2026-04-17T00:00:00Z&to=2026-04-17T23:59:59Z",
        "host": "{{baseUrl}}",
        "path": ["api", "sensor", "history", "{{animalId}}"],
        "query": [
          {
            "key": "from",
            "value": "2026-04-17T00:00:00Z"
          },
          {
            "key": "to",
            "value": "2026-04-17T23:59:59Z"
          }
        ]
      },
      "description": "Get historical sensor readings for an animal within a time range. Requires 'from' and 'to' ISO date query params."
    }
  }
}
