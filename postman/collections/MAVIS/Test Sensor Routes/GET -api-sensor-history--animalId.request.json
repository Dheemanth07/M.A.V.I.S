{
  "name": "GET /api/sensor/history/:animalId",
  "request": {
    "method": "GET",
    "url": {
      "raw": "{{baseUrl}}/api/sensor/history/{{animalId}}?from={{from}}&to={{to}}",
      "host": ["{{baseUrl}}"],
      "path": ["api", "sensor", "history", "{{animalId}}"],
      "query": [
        {
          "key": "from",
          "value": "{{from}}"
        },
        {
          "key": "to",
          "value": "{{to}}"
        }
      ]
    },
    "description": "Gets historical sensor readings for an animal within a date range."
  }
}
