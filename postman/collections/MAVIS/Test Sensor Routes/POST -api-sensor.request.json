{
  "name": "POST /api/sensor",
  "request": {
    "method": "POST",
    "url": "{{baseUrl}}/api/sensor",
    "header": [
      {
        "key": "Content-Type",
        "value": "application/json"
      }
    ],
    "body": {
      "mode": "raw",
      "raw": "{\n  \"animalId\": \"{{animalId}}\",\n  \"physiology\": {\n    \"temperature\": 38.7,\n    \"heartRate\": 92,\n    \"respiratoryRate\": 24,\n    \"bloodOxygen\": 97\n  },\n  \"behavior\": {\n    \"motion\": true,\n    \"steps\": 125,\n    \"lyingDown\": false\n  },\n  \"environment\": {\n    \"ambientTemperature\": 29,\n    \"humidity\": 62,\n    \"aqi\": 45\n  },\n  \"location\": {\n    \"latitude\": 12.9716,\n    \"longitude\": 77.5946,\n    \"zone\": \"farm-1\"\n  },\n  \"device\": {\n    \"batteryLevel\": 82,\n    \"signalStrength\": -67\n  },\n  \"timestamp\": \"2026-04-17T10:30:00.000Z\"\n}",
      "options": {
        "raw": {
          "language": "json"
        }
      }
    },
    "description": "Creates a sensor reading for an existing animal ObjectId."
  }
}
